# Copy this file to 60-hermes-secret.yaml and fill the values, then apply:
#   kubectl apply -f 60-hermes-secret.yaml
# DO NOT commit your filled secret to git.

apiVersion: v1
kind: Secret
metadata:
  name: hermes-api-secret
  namespace: llm-agent
type: Opaque
stringData:
  api-key: smile-dental-course-key
---
apiVersion: v1
kind: Secret
metadata:
  name: llm-api-keys
  namespace: llm-agent
type: Opaque
stringData:
  groq-api-key: ""        # gsk_...  (set this OR google-api-key)
  google-api-key: ""      # AIza...  (alternative to groq-api-key)
