# Lab 12: Template for copying llm-api-keys Secret from llm-agent ns to argo ns.
# Workflow step pods can only mount Secrets from their own namespace; we don't
# move the original (Phase 3 still needs it in llm-agent) — we copy.
#
# Setup (use real value, do NOT commit the actual secret):
#   kubectl get secret llm-api-keys -n llm-agent -o yaml \
#     | sed 's/namespace: llm-agent/namespace: argo/' \
#     | kubectl apply -f -
#
# Verify:
#   kubectl get secret llm-api-keys -n argo
apiVersion: v1
kind: Secret
metadata:
  name: llm-api-keys
  namespace: argo
type: Opaque
data:
  groq-api-key: REPLACE_WITH_BASE64_GROQ_KEY
  google-api-key: REPLACE_WITH_BASE64_GOOGLE_KEY_OR_EMPTY
