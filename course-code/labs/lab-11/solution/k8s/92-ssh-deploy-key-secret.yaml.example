# Lab 11: SSH deploy-key Secret TEMPLATE for Lab 12 git-commit-step.
#
# DO NOT commit a real SSH private key to git. This file ends in `.example` so
# git tracks the template, not the secret. Real value lives in `92-ssh-deploy-key-secret.yaml`
# (gitignored — see ../../../../.gitignore).
#
# Setup steps:
#   1. ssh-keygen -t ed25519 -f /tmp/argo-deploy-key -N ""
#   2. Copy /tmp/argo-deploy-key.pub into GitHub repo Settings → Deploy keys → Add deploy key
#      (CHECK "Allow write access" — git-commit-step needs to push)
#   3. Base64-encode the private key:
#      base64 -i /tmp/argo-deploy-key       # macOS
#      base64 -w 0 /tmp/argo-deploy-key     # Linux
#   4. Replace REPLACE_WITH_BASE64_PRIVATE_KEY below; save as `92-ssh-deploy-key-secret.yaml`
#   5. kubectl apply -f 92-ssh-deploy-key-secret.yaml
#
# The Secret must live in the `argo` namespace (Argo Workflows' default ns) because
# Lab 12's WorkflowTemplate runs there.
apiVersion: v1
kind: Secret
metadata:
  name: git-deploy-key
  namespace: argo
type: Opaque
data:
  id_rsa: REPLACE_WITH_BASE64_PRIVATE_KEY
