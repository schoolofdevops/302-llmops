# Lab 07 — Smile Dental Agent local-mode env
# Copy to .env and fill in ONE of GROQ_API_KEY or GOOGLE_API_KEY before `docker compose up`.

# Hermes API server bearer token (clients use this; static for course)
HERMES_API_KEY=smile-dental-course-key

# LLM provider — pick ONE and uncomment.
# Groq (recommended; faster + clearer free-tier limits — see RESEARCH.md Focus 7)
# GROQ_API_KEY=gsk_your_key_here
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile

# Gemini (alternative)
# GOOGLE_API_KEY=AIza_your_key_here
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# LLM_MODEL=gemini-2.5-flash

# RAG retriever — points at the Day-1 retriever running in your KIND cluster
# (NodePort 30100 if you exposed it, or host.docker.internal:8001 if port-forwarded)
RETRIEVER_URL=http://host.docker.internal:8001
