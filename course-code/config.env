# LLMOps Course — Central Artifact Configuration
# Update these values before starting the labs
CLUSTER_NAME=llmops-kind
PROJECT_DIR=./llmops-project
MODEL_IMAGE_TAG=v1.0.0
# Custom CPU image: stripped-down, no NUMA, works on mac/windows without GPU
VLLM_IMAGE=schoolofdevops/vllm-cpu-nonuma:0.9.1
BASE_MODEL=HuggingFaceTB/SmolLM2-135M-Instruct
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Namespaces (per D-10 — generic functional names)
NS_SERVING=llm-serving
NS_APP=llm-app
NS_MONITORING=monitoring
NS_ARGOCD=argocd
NS_ARGO_WORKFLOWS=argo-workflows

# Day 2 — AgentOps namespace and image pins (Phase 3)
NS_AGENT=llm-agent
SANDBOX_VERSION=v0.4.3
HERMES_IMAGE=nousresearch/hermes-agent:latest
SANDBOX_ROUTER_IMAGE=us-central1-docker.pkg.dev/k8s-staging-images/agent-sandbox/sandbox-router:latest-main
HERMES_API_KEY=smile-dental-course-key
HERMES_PORT=8642
# LLM provider — students set ONE of these in their shell before running Lab 07
# GROQ_API_KEY=gsk_...
# GOOGLE_API_KEY=AIza...
# Default LLM provider config (Groq is the safer primary recommendation per RESEARCH.md Focus 7)
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
# Day 2 observability
OTEL_COLLECTOR_VERSION=0.153.0
TEMPO_VERSION=1.24.4

